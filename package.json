    "radashi": "^12.9.1",
    "tsdown": "^0.22.2",
    "tsnapi": "^0.3.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.2"
